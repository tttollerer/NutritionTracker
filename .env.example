# NutriScan — Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach `.env` (lokal) bzw. trage die Werte in Netlify ein.

# ── White-Label / Branding (Build-Zeit, im Client sichtbar) ───────────────
# Markenname (App-Titel, PWA-Manifest, App-Name in der UI). Default: NutriScan
VITE_BRAND_NAME=NutriScan
# Kurzname fürs Home-Screen-Icon (PWA short_name). Default: NutriScan
VITE_BRAND_SHORT=NutriScan
# Beschreibung im PWA-Manifest.
VITE_BRAND_DESCRIPTION=Kalorien, Makros & Mineralstoffe tracken – mit KI-Unterstützung.
# Akzent-/Theme-Farbe (Browser-UI + Manifest), Hex. Default: #16a34a
VITE_BRAND_THEME_COLOR=#16a34a
# Optionaler Anzeigename des Coaches in der UI (leer = generisch).
VITE_COACH_NAME=

# ── KI-Endpunkte (optional überschreibbar pro Mandant) ────────────────────
# Eigener Coach-/Analyse-Proxy statt der mitgelieferten Netlify-Functions.
# VITE_COACH_URL=/api/coach
# VITE_ANALYZE_URL=/api/analyze

# ── Server-seitig (NUR in Netlify-Env, NIE ins Repo committen) ────────────
# OpenRouter-API-Key (geheim) + optionales Modell.
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Coach-Persönlichkeit pro Mandant (Name + Tonalität im System-Prompt).
# COACH_NAME=
# COACH_PERSONA=ruhig, sachlich, evidenzbasiert
